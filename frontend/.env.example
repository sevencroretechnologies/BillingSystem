# Copy this file to `.env` and adjust the values.
# With Create React App the variables MUST start with REACT_APP_.

# URL of the Laravel backend (no trailing /api).
REACT_APP_API_URL=http://localhost:8000

# Optional company details shown on the invoice print view.
REACT_APP_COMPANY_NAME=Your Company Pvt. Ltd.
REACT_APP_COMPANY_ADDRESS=123 Business Street, City
REACT_APP_COMPANY_PHONE=+00 0000 0000
REACT_APP_COMPANY_EMAIL=billing@example.com
REACT_APP_CURRENCY_SYMBOL=₹
