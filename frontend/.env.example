# URL of the Laravel backend. The frontend will POST to `${VITE_API_URL}/api/...`.
VITE_API_URL=http://localhost:8000

# Optional display overrides (used on the invoice detail page).
VITE_COMPANY_NAME=Your Company Pvt. Ltd.
VITE_COMPANY_ADDRESS=123 Business Street, City, State
VITE_COMPANY_PHONE=+00 0000 0000
VITE_COMPANY_EMAIL=billing@example.com
VITE_CURRENCY_SYMBOL=₹
