APP_NAME="Billing System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite is used by default so the app works without extra setup.
# To switch to MySQL, set DB_CONNECTION=mysql and fill in the DB_* values.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=billing_system
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log

# Currency formatting for invoices. Company details (name, address,
# phone, email, logo) are stored in the `company` database table and
# managed via the /api/company endpoint — not here.
BILLING_CURRENCY=INR
BILLING_CURRENCY_SYMBOL="₹"
