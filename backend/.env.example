APP_NAME="Billing System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite is used by default so the app works without extra setup.
# To switch to MySQL, set DB_CONNECTION=mysql and fill in the DB_* values.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=billing_system
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log

# Company details rendered on the PDF invoice.
COMPANY_NAME="Your Company Pvt. Ltd."
COMPANY_ADDRESS="123 Business Street, City, State"
COMPANY_PHONE="+00 0000 0000"
COMPANY_EMAIL="billing@example.com"
COMPANY_WEBSITE="www.example.com"
COMPANY_TAX_ID=""
COMPANY_CURRENCY=INR
COMPANY_CURRENCY_SYMBOL="₹"
